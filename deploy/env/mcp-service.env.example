# mcp-service

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@<cloud-sql-ip>:5432/mcp_db

# --- Auth ---
JWT_SECRET_KEY=<shared-jwt-secret>
JWT_ALGORITHM=HS256

# --- NATS ---
NATS_URL=nats://nats:4222
NATS_JETSTREAM_ENABLED=true

# --- LLM ---
OPENAI_API_KEY=<openai-key>
OPENAI_LLM_MODEL=gpt-4o-mini

# --- Embedder (must match rag-worker) ---
EMBED_MODEL=text-embedding-3-small
EMBED_BASE_URL=
EMBED_DIMENSION=

# --- Reranker ---
# impl: none | llm | bge (cross-encoder)
RERANK_PROVIDER=none
RERANK_MODEL=gpt-4o-mini
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_TIMEOUT_SECONDS=30
RERANK_BATCH_SIZE=8
RERANK_PASSAGE_CHARS=800

# --- Retrieval ---
SEARCH_TOP_K=20
RERANK_TOP_K=3
RERANK_THRESHOLD=0.7

# --- Vector Store (must match rag-worker) ---
VECTOR_DB_PROVIDER=qdrant
VECTOR_COLLECTION=rag_chatbot
VECTOR_DB_URL=<qdrant-url>
VECTOR_DB_API_KEY=

# --- MCP Server ---
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8003
MCP_INTERNAL_TOKEN=<shared-internal-token>

# --- Pipeline Profile ---
PIPELINE_PROFILE=baseline
AI_PROVIDER=offline
