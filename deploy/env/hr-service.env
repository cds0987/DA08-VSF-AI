# ============================================================================
# hr-service.env — CHỈ biến RIÊNG. hr-service KHÔNG dùng JWT/AI/Qdrant/NATS.
# ============================================================================

HR_HOST=0.0.0.0
HR_PORT=8004

# DB (Cloud SQL) — dùng bởi runtime (config.yaml ${HR_DATABASE_URL}) VÀ hr-migrate
# (alembic env.py đọc HR_DATABASE_URL). MỘT biến cho cả hai -> không split-brain.
HR_DATABASE_URL=postgresql+psycopg://postgres:***REDACTED-DB-PW***@app-postgres:5432/hr_db

# PHẢI = HR_SERVICE_INTERNAL_TOKEN trong mcp-service.env.
HR_INTERNAL_TOKEN=***REDACTED-HR-TOKEN***
