# ============================================================================
# hr-service.env — CHỈ biến RIÊNG. hr-service KHÔNG dùng JWT/AI/Qdrant/NATS.
# ============================================================================

HR_HOST=0.0.0.0
HR_PORT=8004

# 🔑 HR_DATABASE_URL = chứa password -> build trong docker-compose.yml từ ${POSTGRES_PASSWORD}
# (block environment của hr-service + hr-migrate). db-name hr_db = config nằm trong compose.
# KHÔNG đặt ở đây nữa (tránh password trong git + tránh split-brain với compose).

# 🔑 HR_INTERNAL_TOKEN = SECRET -> secret.env (PHẢI = HR_SERVICE_INTERNAL_TOKEN).

# Leave WRITE: người duyệt mặc định khi nhân viên không có manager (manager_user_id NULL).
# = uuid5(sep@company.com) tất định trong seed_user.py (cùng namespace mọi repo) -> đơn
# route về sếp; sếp login JWT mang đúng id này -> /leave-approvals khớp, duyệt được.
HR_DEFAULT_APPROVER=2dc14f72-64f6-5361-87aa-15e859f7cf90
