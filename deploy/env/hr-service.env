HR_HOST=0.0.0.0
HR_PORT=8004

# 🔑 HR_DATABASE_URL = chứa password -> build trong docker-compose.yml từ ${POSTGRES_PASSWORD}
# (block environment của hr-service + hr-migrate). db-name hr_db = config nằm trong compose.
# KHÔNG đặt ở đây nữa (tránh password trong git + tránh split-brain với compose).

# 🔑 HR_INTERNAL_TOKEN = SECRET -> secret.env (PHẢI = HR_SERVICE_INTERNAL_TOKEN).
