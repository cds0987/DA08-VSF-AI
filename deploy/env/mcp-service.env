# mcp-service — CLOUD production (OpenAI + Qdrant Cloud)
DATABASE_URL=postgresql+psycopg://postgres:***REDACTED-DB-PW***@34.87.63.152:5432/mcp_db
JWT_SECRET_KEY=***REDACTED-JWT-SECRET***
JWT_ALGORITHM=HS256
NATS_URL=nats://nats:4222
NATS_JETSTREAM_ENABLED=true

# === AI: OpenAI ===
AI_PROVIDER=openai
OPENAI_API_KEY=***REDACTED-OPENAI-KEY***
OPENAI_LLM_MODEL=gpt-4o-mini

# Embedder (PHẢI khớp rag-worker để contract fingerprint trùng)
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSION=1536

# Reranker (none = tắt; bật thì dùng OpenAI gpt-4o-mini)
RERANK_PROVIDER=none
RERANK_MODEL=gpt-4o-mini
RERANK_TIMEOUT_SECONDS=30
RERANK_BATCH_SIZE=8
RERANK_PASSAGE_CHARS=800

# Retrieval
SEARCH_TOP_K=20
RERANK_TOP_K=3
RERANK_THRESHOLD=0.7

# === Vector store: Qdrant Cloud (PHẢI khớp rag-worker) ===
VECTOR_DB_PROVIDER=qdrant
VECTOR_COLLECTION=rag_chatbot
VECTOR_DB_URL=https://a0016cd3-97f1-44d1-a166-cc1c7de503ce.australia-southeast1-0.gcp.cloud.qdrant.io:6333
VECTOR_DB_API_KEY=***REDACTED-QDRANT-KEY***

# MCP Server
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8003

# Pipeline
PIPELINE_PROFILE=baseline
