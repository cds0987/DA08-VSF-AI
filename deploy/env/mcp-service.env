# ============================================================================
# mcp-service.env — CHỈ biến RIÊNG. mcp = SEARCH-ONLY + hr_query. Embedder/vector
# contract LẤY TỪ common.env -> tự khớp rag-worker, KHÔNG khai lại ở đây.
# ============================================================================

MCP_HOST=0.0.0.0
MCP_PORT=8003
PIPELINE_PROFILE=baseline
# 🔑 MCP_INTERNAL_TOKEN = SECRET -> secret.env. query-service phải gửi đúng token này. Trống = auth TẮT.

TOOL_RAG_SEARCH_ENABLED=1
TOOL_HR_QUERY_ENABLED=1
# Leave WRITE (create/update/cancel_leave_request) — bật để chatbot tạo/hủy đơn nghỉ.
TOOL_LEAVE_WRITE_ENABLED=1
# Hàng đợi duyệt của approver (read-only) — bật để sếp hỏi 'đơn nào chờ tôi duyệt'.
TOOL_LEAVE_APPROVALS_ENABLED=1
# Danh mục loại nghỉ phép (read-only) — bật để trả lời 'có loại nghỉ nào'.
TOOL_LEAVE_TYPES_ENABLED=1
HR_SERVICE_URL=http://hr-service:8004
# 🔑 HR_SERVICE_INTERNAL_TOKEN = SECRET -> secret.env (PHẢI = HR_INTERNAL_TOKEN).

# Reranker + retrieval (mcp-only).
# none = NoopReranker: sort thuần theo cosine score từ Qdrant, không filter thêm.
# lexical = overlap token ratio (không đáng tin, kéo thứ tự sai khi query dùng từ khác).
# llm = LLM-judge rerank qua chat.completions (cần model có alias trong ai-router; gpt-4o-mini
#       KHÔNG có alias -> 503 -> fallback vector-order = coi như tắt. Tránh dùng tới khi sửa alias).
# cohere = rerank endpoint CHUYÊN DỤNG (Cohere API format) 'cohere/rerank-4-pro'. CHUẨN HÓA QUA
#          AI-ROUTER (không gọi thẳng OpenRouter): base_url = ai-router /v1 -> POST /v1/rerank;
#          ai-router map alias cohere/rerank-4-pro -> capability rerank_api -> OpenRouter (giữ
#          nguyên model + response Cohere). Key OpenRouter nằm TRONG pool ai-router (1 cổng).
#          Lỗi -> fallback vector-order (non-fatal).
RERANK_PROVIDER=cohere
RERANK_MODEL=cohere/rerank-v3.5             # alias -> capability rerank_api ở ai-router (đổi 2026-06-25 từ rerank-4-pro=rerank-v4.0-pro)
RERANK_BASE_URL=http://ai-router:8010/v1    # QUA ai-router, KHÔNG openrouter.ai trực tiếp
# Bearer tới ai-router = AIROUTER_INTERNAL_TOKEN (config.yaml đọc thẳng, secret.env). KHÔNG cần
# key OpenRouter ở mcp nữa — ai-router tự route cohere bằng 5 key OpenRouter sẵn có (chung credit).
RERANK_TIMEOUT_SECONDS=30
RERANK_BATCH_SIZE=8
RERANK_PASSAGE_CHARS=800
SEARCH_TOP_K=40
RERANK_TOP_K=5
RERANK_THRESHOLD=0.35
# Đa dạng document: tối đa N chunk/doc trong top-k rerank -> chống 1 doc thống trị (chôn doc
# nhỏ/đúng). Rerank pool = RERANK_TOP_K * POOL rồi chọn đa dạng. 0 = tắt.
RERANK_MAX_PER_DOC=3
RERANK_DIVERSITY_POOL=3
