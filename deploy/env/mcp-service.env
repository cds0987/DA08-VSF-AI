DATABASE_URL=postgresql+asyncpg://appuser:apppassword@postgres:5432/mcp_db
JWT_SECRET_KEY=local-dev-secret-change-in-prod
JWT_ALGORITHM=HS256
NATS_URL=nats://nats:4222
NATS_JETSTREAM_ENABLED=true

# === AI gateway (OpenRouter) — đồng bộ với root .env ===
AI_PROVIDER=auto
EMBED_API_KEY=***REDACTED-OPENROUTER-KEY***
EMBED_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=***REDACTED-OPENROUTER-KEY***
OPENAI_LLM_MODEL=openai/gpt-4o-mini

# Embedder (PHẢI khớp rag-worker để contract fingerprint trùng)
EMBED_MODEL=openai/text-embedding-3-small
EMBED_DIMENSION=1536

# Reranker (none = tắt rerank cho lần chạy đầu, ít điểm fail hơn)
RERANK_PROVIDER=none
RERANK_MODEL=openai/gpt-4o-mini
RERANK_BASE_URL=https://openrouter.ai/api/v1
RERANK_API_KEY=***REDACTED-OPENROUTER-KEY***
RERANK_TIMEOUT_SECONDS=30
RERANK_BATCH_SIZE=8
RERANK_PASSAGE_CHARS=800

# Retrieval
SEARCH_TOP_K=20
RERANK_TOP_K=3
RERANK_THRESHOLD=0.7

# Vector Store (PHẢI khớp rag-worker — Qdrant container)
VECTOR_DB_PROVIDER=qdrant
VECTOR_COLLECTION=rag_chatbot
VECTOR_DB_URL=http://qdrant:6333
VECTOR_DB_API_KEY=

# MCP Server
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8003

# Pipeline
PIPELINE_PROFILE=baseline
