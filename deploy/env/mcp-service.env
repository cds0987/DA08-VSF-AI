# ============================================================================
# mcp-service.env — CHỈ biến RIÊNG. mcp = SEARCH-ONLY + hr_query. Embedder/vector
# contract LẤY TỪ common.env -> tự khớp rag-worker, KHÔNG khai lại ở đây.
# ============================================================================

MCP_HOST=0.0.0.0
MCP_PORT=8003
PIPELINE_PROFILE=baseline
# 🔑 MCP_INTERNAL_TOKEN = SECRET -> secret.env. query-service phải gửi đúng token này. Trống = auth TẮT.

TOOL_RAG_SEARCH_ENABLED=1
TOOL_HR_QUERY_ENABLED=1
# Leave WRITE (create/update/cancel_leave_request) — bật để chatbot tạo/hủy đơn nghỉ.
TOOL_LEAVE_WRITE_ENABLED=1
# Hàng đợi duyệt của approver (read-only) — bật để sếp hỏi 'đơn nào chờ tôi duyệt'.
TOOL_LEAVE_APPROVALS_ENABLED=1
# Danh mục loại nghỉ phép (read-only) — bật để trả lời 'có loại nghỉ nào'.
TOOL_LEAVE_TYPES_ENABLED=1
HR_SERVICE_URL=http://hr-service:8004
# 🔑 HR_SERVICE_INTERNAL_TOKEN = SECRET -> secret.env (PHẢI = HR_INTERNAL_TOKEN).

# Reranker + retrieval (mcp-only).
# none = NoopReranker: sort thuần theo cosine score từ Qdrant, không filter thêm.
# lexical = overlap token ratio (không đáng tin, kéo thứ tự sai khi query dùng từ khác).
# llm = LLM-judge rerank (chất lượng tốt nhưng cần calibrate threshold; để sau).
RERANK_PROVIDER=llm
RERANK_MODEL=gpt-4o-mini
RERANK_BASE_URL=
# 🔑 RERANK_API_KEY = SECRET -> secret.env (dùng chung OPENAI_API_KEY nếu dùng OpenAI)
RERANK_TIMEOUT_SECONDS=30
RERANK_BATCH_SIZE=8
RERANK_PASSAGE_CHARS=800
SEARCH_TOP_K=40
RERANK_TOP_K=5
RERANK_THRESHOLD=0.05
