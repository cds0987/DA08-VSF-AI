# 🔑 DATABASE_URL = chứa password -> build trong docker-compose.yml từ ${POSTGRES_PASSWORD}
# (block environment của user-service + user-migrate + user-backfill; db-name user_db = config
# trong compose). KHÔNG đặt ở đây nữa (tránh password trong git + split-brain).

ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
FAILED_LOGIN_THRESHOLD=5
LOCKOUT_MINUTES=15
