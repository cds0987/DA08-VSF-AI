# query-service
APP_ENV=production
DATABASE_URL=postgresql+asyncpg://user:password@<cloud-sql-ip>:5432/query_db
AUTH_MODE=user_service
USER_SERVICE_URL=http://user-service:8000
JWT_SECRET_KEY=<strong-shared-jwt-secret-if-auth-mode-jwt>
JWT_ALGORITHM=HS256
REDIS_URL=redis://redis:6379/0
RATE_LIMITER_MODE=redis
LLM_MODE=openai
OPENAI_API_KEY=<openai-key>
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MCP_MODE=real
MCP_SERVICE_URL=http://mcp-service:8003
MCP_TIMEOUT_SECONDS=10
NATS_MODE=nats
NATS_URL=nats://nats:4222
NATS_JETSTREAM_ENABLED=true
ENABLE_DEV_ENDPOINTS=false
RAG_RESULT_LIMIT=3
RAG_SCORE_THRESHOLD=0.70
NATS_PROCESSED_EVENT_MAX_SIZE=10000
NATS_PROCESSED_EVENT_TTL_SECONDS=86400
QDRANT_URL=<qdrant-url>
QDRANT_COLLECTION=rag_chatbot
LANGFUSE_PUBLIC_KEY=<langfuse-public-key>
LANGFUSE_SECRET_KEY=<langfuse-secret-key>
LANGFUSE_HOST=http://langfuse:3100
