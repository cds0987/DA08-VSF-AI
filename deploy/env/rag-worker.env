# ============================================================================
# rag-worker.env — CHỈ biến RIÊNG. Biến chung ở common.env. rag-worker = INGEST-ONLY.
# ============================================================================

# 🔑 DATABASE_URL = chứa password -> build trong docker-compose.yml từ ${POSTGRES_PASSWORD}
# (block environment của rag-worker + rag-migrate; db-name rag_db = config trong compose).

# Parser / object-storage nguồn (PARSER_IMPL=s3 -> tải từ GCS qua S3-interop API).
PARSER_IMPL=s3
SOURCE_ROOT=/tmp
ARTIFACT_ROOT=/tmp/artifacts
S3_ENDPOINT_URL=https://storage.googleapis.com
# 🔑 S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = SECRET (GCS HMAC) -> secret.env.
S3_REGION=auto
S3_SOURCE_BUCKET=vintravel-chatbot-docs-dev

# ── 2 ĐƯỜNG DIRECT, 2 KEY RIÊNG (1 key 2 chỗ = SAI: OpenRouter ≠ OpenAI) ─────────────────
# embed -> OpenRouter THẲNG (qwen3-embedding-4b, OpenRouter key).
# caption/ocr -> OpenAI THẲNG (gpt-4o-mini, OpenAI key) — KHÔNG kế thừa embed_url, KHÔNG qua
# ai-router (tránh race auth startup + dùng đúng key OpenAI). Key wire ở compose (env_file
# không substitute ${...}). BLUE-GREEN: chỉ rag-worker đổi embed; mcp giữ common (te3s).
EMBED_BASE_URL=https://openrouter.ai/api/v1
EMBED_MODEL=qwen/qwen3-embedding-4b
EMBED_DIMENSION=2560
CAPTION_BASE_URL=https://api.openai.com/v1   # ocr/caption -> OpenAI THẲNG (không kế thừa OpenRouter)
CAPTION_MODEL=gpt-4o-mini
OCR_MODEL=gpt-4o-mini
VECTOR_HYBRID=true                           # bật BM25 named dense+sparse cho collection mới

# Caption-at-ingest: TẮT (bỏ bước summary sau parse). Pipeline còn THUẦN rule-based:
#   parse -> split parent/child (theo heading) -> embed RAW child -> qdrant.
# Engine xử lý captioner=None native (skip block caption, payload.caption = raw child).
# Lý do: embedding mạnh (qwen3-embedding-4b) đủ recall, không cần caption khử vocab-mismatch;
# bỏ luôn chi phí + độ trễ AI ở ingest. Bật lại = CAPTION_ENABLED=1. Có hiệu lực từ reingest kế.
CAPTION_ENABLED=false
CAPTION_MODEL=gpt-4o-mini          # giữ tham chiếu; KHÔNG dùng khi CAPTION_ENABLED=false

# Cái gì được EMBED (vector dense). raw = chỉ raw child chunk (khớp style query ngắn ->
# cosine cao). caption_raw/caption = cần caption (đã tắt). child_text payload LUÔN = raw.
# Đổi giá trị này -> CẦN re-ingest để áp vector mới.
EMBED_TARGET=raw

# NATS stream theo contract infra/nats/subjects.md = DOC_EVENTS.
# VERIFY-ONLY (AUTO_CREATE=0): stream do nats-bootstrap one-shot provision TRƯỚC
# (nguồn duy nhất). rag-worker chỉ verify fail-closed -> KHÔNG đua add_stream gây
# overlap. Thiếu stream -> rag-worker từ chối start ingest (lộ lỗi sớm, không
# degrade âm thầm). Dev/CI (docker-compose.localtest) vẫn để =1 vì NATS ephemeral.
NATS_STREAM=DOC_EVENTS
NATS_STREAM_AUTO_CREATE=0

# ── LangSmith ingest tracing (TÁCH project query-service) ────────────────────
# Trace luồng ingest (parse/OCR -> chunk -> caption -> embed -> qdrant) lên LangSmith.
# project 'vsf-rag-ingest' KHÁC 'vsf-rag-chatbot' (query-service) -> phân biệt rõ
# ingest vs query. 🔑 LANGSMITH_API_KEY = SECRET -> secret.env (thiếu -> tự tắt, không
# crash). sample_rate=1.0: volume ingest thấp nên trace mọi doc; hạ nếu cần tiết kiệm.
LANGSMITH_ENABLED=1
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=vsf-rag-ingest
LANGSMITH_SAMPLE_RATE=1.0
