# === AI gateway (OpenRouter) — đồng bộ với root .env ===
AI_PROVIDER=auto
EMBED_API_KEY=***REDACTED-OPENROUTER-KEY***
EMBED_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=***REDACTED-OPENROUTER-KEY***
EMBED_MODEL=openai/text-embedding-3-small
CAPTION_MODEL=openai/gpt-4o-mini
RERANK_MODEL=openai/gpt-4o-mini
EMBED_DIMENSION=1536

# GEMINI_API_KEY: chỉ cần nếu dùng Gemini
GEMINI_API_KEY=

# === Metadata DB (rag-worker dùng sync SQLAlchemy + psycopg v3) ===
DATABASE_URL=postgresql+psycopg://appuser:apppassword@postgres:5432/rag_db

# === NATS ===
NATS_URL=nats://nats:4222
NATS_JETSTREAM_ENABLED=true
# Dev/local: rag-worker tự dựng stream DOCS (doc.ingest/status/access).
NATS_STREAM_AUTO_CREATE=1

# === Object storage nguồn (MinIO qua giao thức S3) ===
# rag-worker nhận source_uri=s3://documents/... rồi tự tải về từ MinIO.
# PARSER_IMPL=s3 -> dùng S3SourceParser (tải remote) thay vì local parser.
PARSER_IMPL=s3
# Thư mục tải file tạm + artifact — /app thuộc root, appuser không ghi được -> dùng /tmp.
SOURCE_ROOT=/tmp
ARTIFACT_ROOT=/tmp/artifacts
# Nơi lưu artifact markdown — mặc định /app/src/... không ghi được -> /tmp.
ARTIFACT_ROOT=/tmp/.artifacts
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=auto
S3_SOURCE_BUCKET=documents

# === Vector store (Qdrant container — KHÔNG để trống) ===
VECTOR_DB_PROVIDER=qdrant
VECTOR_COLLECTION=rag_chatbot
VECTOR_DB_URL=http://qdrant:6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_chatbot

# GCS: để trống khi test local (upload file sẽ lỗi — bình thường)
GCS_BUCKET=
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Langfuse: để trống nếu không dùng
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
