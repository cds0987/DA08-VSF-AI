# rag-worker — CLOUD production (OpenAI + Qdrant Cloud + Cloud SQL + GCS)
APP_ENV=production
LOG_LEVEL=INFO

# === AI: OpenAI ===
AI_PROVIDER=openai
OPENAI_API_KEY=***REDACTED-OPENAI-KEY***
EMBED_MODEL=text-embedding-3-small
CAPTION_MODEL=gpt-4o-mini
RERANK_MODEL=gpt-4o-mini
EMBED_DIMENSION=1536
GEMINI_API_KEY=

# === Metadata DB: Cloud SQL (driver psycopg v3; '@' trong pass -> %40) ===
DATABASE_URL=postgresql+psycopg://postgres:***REDACTED-DB-PW***@34.87.63.152:5432/rag_db

# === NATS ===
NATS_URL=nats://nats:4222
NATS_JETSTREAM_ENABLED=true
NATS_STREAM_AUTO_CREATE=1

# === Object storage nguồn: GCS qua S3-interop (HMAC) ===
PARSER_IMPL=s3
SOURCE_ROOT=/tmp
ARTIFACT_ROOT=/tmp/artifacts
S3_ENDPOINT_URL=https://storage.googleapis.com
S3_ACCESS_KEY_ID=***REDACTED-GCS-HMAC-KEY***
S3_SECRET_ACCESS_KEY=***REDACTED-GCS-HMAC-SECRET***
S3_REGION=auto
S3_SOURCE_BUCKET=vsf-rag-chatbot-docs-dev

# === Vector store: Qdrant Cloud (URL bắt buộc :6333 + API key) ===
VECTOR_DB_PROVIDER=qdrant
VECTOR_COLLECTION=rag_chatbot
VECTOR_DB_URL=https://a0016cd3-97f1-44d1-a166-cc1c7de503ce.australia-southeast1-0.gcp.cloud.qdrant.io:6333
VECTOR_DB_API_KEY=***REDACTED-QDRANT-KEY***
QDRANT_URL=https://a0016cd3-97f1-44d1-a166-cc1c7de503ce.australia-southeast1-0.gcp.cloud.qdrant.io:6333
QDRANT_COLLECTION=rag_chatbot

# === GCS (metadata, cho client native nếu cần) ===
GCS_BUCKET=vsf-rag-chatbot-docs-dev
GCP_PROJECT_ID=vsf-rag-chatbot-dev
GOOGLE_APPLICATION_CREDENTIALS=

# Langfuse: để trống nếu không dùng
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
