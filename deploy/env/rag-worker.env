# ============================================================================
# rag-worker.env — CHỈ biến RIÊNG. Biến chung ở common.env. rag-worker = INGEST-ONLY.
# ============================================================================

# Metadata DB (Cloud SQL) — driver psycopg v3 (SYNC). Dùng bởi runtime + rag-migrate.
DATABASE_URL=postgresql+psycopg://postgres:***REDACTED-DB-PW***@34.87.63.152:5432/rag_db

# Parser / object-storage nguồn (PARSER_IMPL=s3 -> tải từ GCS qua S3-interop API).
PARSER_IMPL=s3
SOURCE_ROOT=/tmp
ARTIFACT_ROOT=/tmp/artifacts
S3_ENDPOINT_URL=https://storage.googleapis.com
S3_ACCESS_KEY_ID=***REDACTED-GCS-HMAC-KEY***
S3_SECRET_ACCESS_KEY=***REDACTED-GCS-HMAC-SECRET***
S3_REGION=auto
S3_SOURCE_BUCKET=vsf-rag-chatbot-docs-dev

# Caption-at-ingest (ingest-only).
CAPTION_MODEL=gpt-4o-mini

# NATS stream theo contract infra/nats/subjects.md = DOC_EVENTS (cùng stream
# document-service tạo). KHÔNG để default "DOCS" -> 2 stream cùng subject =
# JetStream overlap -> rag-worker không subscribe được doc.ingest.
NATS_STREAM=DOC_EVENTS
NATS_STREAM_AUTO_CREATE=1
