# ============================================================================
# query-service.env — CHỈ biến RIÊNG. Biến chung ở common.env (JWT, OPENAI_API_KEY,
# QDRANT_*, NATS_URL, REDIS_URL, Langfuse, CORS).
# ============================================================================

SERVICE_NAME=query-service

# DB (Cloud SQL) — driver psycopg v3 (async-capable; khớp state đang chạy trên VM).
DATABASE_URL=postgresql+psycopg://postgres:***REDACTED-DB-PW***@34.87.63.152:5432/query_db

# Auth: jwt | user_service (mock CẤM ở production).
AUTH_MODE=user_service
USER_SERVICE_URL=http://user-service:8000

# LLM: openai | mock (mock CẤM ở production). OPENAI_API_KEY kế thừa common.env;
# nếu cần provider LLM khác embedder thì thêm OPENAI_API_KEY ngay đây (override).
LLM_MODE=openai
OPENAI_LLM_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# MCP: real (mock CẤM ở production). Token PHẢI = MCP_INTERNAL_TOKEN của mcp-service.
MCP_MODE=real
MCP_SERVICE_URL=http://mcp-service:8003
MCP_INTERNAL_TOKEN=***REDACTED-MCP-TOKEN***

# NATS: nats (mock CẤM ở production).
NATS_MODE=nats

# Rate limiter: redis BẮT BUỘC ở production (REDIS_URL ở common.env).
RATE_LIMITER_MODE=redis

USE_LANGGRAPH=true
GUARDRAILS_MODE=off
# Danh sách backend (phẩy). Chạy SONG SONG để test langsmith mà KHÔNG bỏ langfuse đang ổn.
# Thiếu key backend nào -> tự bỏ backend đó (không crash). Bỏ langsmith = về "langfuse".
OBSERVABILITY_MODE=langfuse,langsmith
# LangSmith: key + project. EU dùng https://eu.api.smith.langchain.com.
LANGSMITH_API_KEY=***REDACTED-LANGSMITH-KEY***
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=VFS-CHATBOT
ENABLE_DEV_ENDPOINTS=false

# Model-price catalog -> tự tính cost LLM gửi vào langfuse (server v2 không có pricing
# model mới). Runtime đọc model_prices.json (TOÀN BỘ dataset OpenRouter) bundle sẵn trong
# image (builder stage refresh từ HF lúc build). Tắt = MODEL_PRICE_ENABLED=false.
# MODEL_PRICE_OVERRIDE_PATH: trỏ tới 1 file JSON (vd mount volume) để ĐÈ giá nóng không
# cần rebuild — bỏ trống = chỉ dùng bản bundle.
MODEL_PRICE_ENABLED=true
# MODEL_PRICE_OVERRIDE_PATH=/app/price-override/model_prices.json

RAG_SCORE_THRESHOLD=0.35
RAG_RESULT_LIMIT=3
