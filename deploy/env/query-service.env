ALLOWED_ORIGINS=http://34.158.47.236,http://localhost:3000,http://localhost:3001

SEMANTIC_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_THRESHOLD=0.95
RAG_SCORE_THRESHOLD=0.70
QUERY_RATE_LIMIT_PER_MINUTE=20
NOTIFICATION_KEEPALIVE_SECONDS=25

INTENT_CLASSIFIER_MODE=hybrid
INTENT_RULE_CONFIDENCE_THRESHOLD=0.90
INTENT_EMBEDDING_CONFIDENCE_THRESHOLD=0.78
