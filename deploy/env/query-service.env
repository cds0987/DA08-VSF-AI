# ============================================================================
# query-service.env — CHỈ biến RIÊNG. Biến chung ở common.env (JWT, OPENAI_API_KEY,
# QDRANT_*, NATS_URL, REDIS_URL, Langfuse, CORS).
# ============================================================================

SERVICE_NAME=query-service

# 🔑 DATABASE_URL = chứa password -> build trong docker-compose.yml từ ${POSTGRES_PASSWORD}
# (block environment của query-service; db-name query_db = config trong compose).

# Auth: jwt | user_service (mock CẤM ở production).
AUTH_MODE=user_service
USER_SERVICE_URL=http://user-service:8000

# LLM: openai | mock (mock CẤM ở production). OPENAI_API_KEY kế thừa common.env;
# nếu cần provider LLM khác embedder thì thêm OPENAI_API_KEY ngay đây (override).
LLM_MODE=openai
OPENAI_LLM_MODEL=gpt-5.4-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Timeout (read) cho mỗi LLM call qua OpenAI/ai-router. Worker non-streaming (rag/hr/analyze)
# dùng làm trần cứng -> phải khớp worker_timeout_seconds (agents.yaml=60) để worker chạy được
# >30s khi model reasoning nặng. Streaming (synthesize/verify): đây là gap giữa token.
OPENAI_TIMEOUT_SECONDS=60

# ── AI Router (cân bằng key + cost-per-key) — MASTER SWITCH, mặc định TẮT ──────
# Kích hoạt AN TOÀN theo thứ tự (sau khi parity test xanh + canary):
#   1) LLM_MODEL_ADAPTER=chat        -> đổi Responses API sang Chat Completions (chuẩn portable).
#   2) OPENAI_BASE_URL=http://ai-router:8010/v1  -> route LLM qua router.
#   3) OPENAI_API_KEY (secret.env)   -> đặt = AIROUTER_INTERNAL_TOKEN (router giữ key thật).
# Khi route: `model` gửi đi = CAPABILITY (LLM_CAPABILITY/INTENT_CAPABILITY/GUARDRAIL_CAPABILITY).
# Rollback tức thì: xoá OPENAI_BASE_URL hoặc LLM_MODEL_ADAPTER=responses -> về thẳng OpenAI.
LLM_MODEL_ADAPTER=chat
OPENAI_BASE_URL=http://ai-router:8010/v1
LLM_CAPABILITY=think
INTENT_CAPABILITY=triage
GUARDRAIL_CAPABILITY=guardrail

# MCP: real (mock CẤM ở production). Token PHẢI = MCP_INTERNAL_TOKEN của mcp-service.
MCP_MODE=real
MCP_SERVICE_URL=http://mcp-service:8003
# 🔑 MCP_INTERNAL_TOKEN = SECRET -> secret.env (PHẢI = token của mcp-service).

# Leave WRITE REST (frontend -> query-service -> hr-service). URL không secret;
# 🔑 HR_INTERNAL_TOKEN = SECRET -> secret.env (PHẢI = HR_INTERNAL_TOKEN của hr-service).
HR_SERVICE_URL=http://hr-service:8004

# NATS: nats (mock CẤM ở production).
NATS_MODE=nats

# Rate limiter: redis BẮT BUỘC ở production (REDIS_URL ở common.env).
RATE_LIMITER_MODE=redis
# ⚠️ LOAD-TEST (tạm) — nâng trần để đo elastic_banded. Revert 20/60/600/3 sau khi đo.
QUERY_RATE_LIMIT_PER_MINUTE=1000000
QUERY_RATE_LIMIT_PER_IP_PER_MINUTE=1000000
QUERY_RATE_LIMIT_GLOBAL_PER_MINUTE=1000000
QUERY_MAX_CONCURRENT_PER_USER=1000

USE_LANGGRAPH=true
# MOSA tách answer node: think=planner (chọn tool), answer=generator (sinh câu trả lời +
# stream token riêng). Bật bản mới trên prod (đang dev). Tắt tức thì: =false (think tự sinh).
AGENT_SPLIT_ANSWER=true
# Gộp triage (phân loại) vào think: bỏ 1 LLM call, hết domino. think tự phân loại + suy luận
# + gọi tool; SAFETY do rule-shortcut giữ. Tắt: =false (giữ triage riêng).
AGENT_MERGED_REASON=true
# Verify "think 2" (sufficiency gate): sau khi gom tool results, deepseek-pro tổng hợp lại +
# quyết ĐỦ chưa -> đủ thì synthesize, thiếu thì tra thêm (trong max_iterations). Đổi latency lấy
# accuracy (latency che bằng streaming). Chỉ hiệu lực khi AGENT_SPLIT_ANSWER=true. Tắt: =false.
AGENT_VERIFY_SUFFICIENCY=true
# MOSA Orchestrator-Workers (bật path mới): router(deepseek-pro) -> workers gpt-5.4-mini SONG
# SONG -> synthesize(deepseek-flash). e2e PHẢI bật cùng giá trị (test_e2e_and_prod_agent_mode_
# consistent gác) -> CI xanh = path này đã validate end-to-end. Rollback tức thì: =react (hoặc xoá).
AGENT_MODE=orchestrator_workers
# llm_api: chặn prompt-injection bằng LLM-judge gọi qua provider OpenAI-compatible sẵn có
# + che PII (email/SĐT/CCCD) regex. KHÔNG nhúng model/torch vào container. Thêm ~1 LLM
# call nhẹ mỗi query (fail-open: provider lỗi -> không chặn). GUARDRAIL_MODEL rỗng = dùng
# OPENAI_LLM_MODEL cho việc judge.
GUARDRAILS_MODE=llm_api
GUARDRAIL_MODEL=
# Danh sách backend (phẩy). LangSmith TẠM TẮT (team chốt 2026-06-18: dồn về Langfuse vì
# LangSmith không chuyển hướng được) -> chỉ langfuse. Bật lại: thêm 'langsmith' vào đây
# + set LANGSMITH_API_KEY trong secret.env (thiếu key -> tự bỏ backend, không crash).
OBSERVABILITY_MODE=langfuse
# 🔑 LANGSMITH_API_KEY = SECRET -> secret.env (đặt giá trị thật trên VM, KHÔNG commit).
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=vsf-rag-chatbot
ENABLE_DEV_ENDPOINTS=false

# Model-price catalog -> tự tính cost LLM gửi vào langfuse (server v2 không có pricing
# model mới). Runtime đọc model_prices.json (TOÀN BỘ dataset OpenRouter) bundle sẵn trong
# image (builder stage refresh từ HF lúc build). Tắt = MODEL_PRICE_ENABLED=false.
# MODEL_PRICE_OVERRIDE_PATH: trỏ tới 1 file JSON (vd mount volume) để ĐÈ giá nóng không
# cần rebuild — bỏ trống = chỉ dùng bản bundle.
MODEL_PRICE_ENABLED=true
# MODEL_PRICE_OVERRIDE_PATH=/app/price-override/model_prices.json

RAG_SCORE_THRESHOLD=0.35
RAG_RESULT_LIMIT=3
