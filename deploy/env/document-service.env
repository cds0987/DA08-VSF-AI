# document-service — CLOUD production (Cloud SQL + GCS qua S3-interop)
DATABASE_URL=postgresql+asyncpg://postgres:***REDACTED-DB-PW***@34.87.63.152:5432/doc_db
JWT_SECRET_KEY=***REDACTED-JWT-SECRET***
JWT_ALGORITHM=HS256
NATS_URL=nats://nats:4222
NATS_JETSTREAM_ENABLED=true

# Storage: GCS qua S3-interop (HMAC) — không cần service-account JSON.
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://storage.googleapis.com
S3_BUCKET=vsf-rag-chatbot-docs-dev
S3_ACCESS_KEY_ID=***REDACTED-GCS-HMAC-KEY***
S3_SECRET_ACCESS_KEY=***REDACTED-GCS-HMAC-SECRET***
S3_REGION=auto

# GCS native (chỉ dùng khi STORAGE_BACKEND=gcs + có gcp-sa.json)
GCS_BUCKET=vsf-rag-chatbot-docs-dev
GCP_PROJECT_ID=vsf-rag-chatbot-dev
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json
