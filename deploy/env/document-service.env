# ============================================================================
# document-service.env — CHỈ biến RIÊNG. Biến chung ở common.env (JWT, NATS_URL,
# CORS_ORIGINS).
# ============================================================================

# 🔑 DATABASE_URL = chứa password -> build trong docker-compose.yml từ ${POSTGRES_PASSWORD}
# (block environment của document-service + doc-migrate; db-name doc_db = config trong compose).

# Storage: prod = gcs (SDK native). KEYLESS — VM gắn SA vsf-storage -> SDK tự dùng
# ADC qua metadata server, KHÔNG cần key file (org policy chặn tạo SA key). s3 chỉ local/e2e.
STORAGE_BACKEND=gcs
GCS_BUCKET=vintravel-chatbot-docs-dev
GCP_PROJECT_ID=vintravel-chatbot
# KHÔNG set GOOGLE_APPLICATION_CREDENTIALS -> SDK fallback ADC (VM-attached SA).

# Allow_list loại file cho upload (chính sách). RỖNG = LINH HOẠT theo rag-worker:
# cho phép TẤT CẢ loại rag-worker parse được (app/supported_formats.json — gồm pdf,
# docx, txt, xlsx, csv, pptx, md, html, htm, xls + ảnh png/jpg/jpeg/tif/tiff/bmp/gif/
# webp). rag-worker thêm reader -> doc-service tự nhận, KHÔNG phải sửa env. Chỉ set
# subset ở đây khi muốn SIẾT (loại set phải ⊆ manifest, nếu không fail-fast lúc start).
DOC_ALLOWED_EXTENSIONS=

# hr-service = NGUỒN SỰ THẬT của department. ACL secret-doc đọc department SỐNG từ đây qua
# endpoint công khai GET /hr/employees/departments (KHÔNG cần token). Mặc định trong config trỏ
# hr-service:8004 — khai tường minh cho khớp query-service/mcp-service.
HR_SERVICE_URL=http://hr-service:8004
