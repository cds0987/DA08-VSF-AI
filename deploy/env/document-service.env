# ============================================================================
# document-service.env — CHỈ biến RIÊNG. Biến chung ở common.env (JWT, NATS_URL,
# CORS_ORIGINS).
# ============================================================================

# 🔑 DATABASE_URL = chứa password -> build trong docker-compose.yml từ ${POSTGRES_PASSWORD}
# (block environment của document-service + doc-migrate; db-name doc_db = config trong compose).

# Storage: prod = gcs (SDK native). KEYLESS — VM gắn SA vsf-storage -> SDK tự dùng
# ADC qua metadata server, KHÔNG cần key file (org policy chặn tạo SA key). s3 chỉ local/e2e.
STORAGE_BACKEND=gcs
GCS_BUCKET=vintravel-chatbot-docs-dev
GCP_PROJECT_ID=vintravel-chatbot
# KHÔNG set GOOGLE_APPLICATION_CREDENTIALS -> SDK fallback ADC (VM-attached SA).
