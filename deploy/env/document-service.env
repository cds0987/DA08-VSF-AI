# ============================================================================
# document-service.env — CHỈ biến RIÊNG. Biến chung ở common.env (JWT, NATS_URL,
# CORS_ORIGINS).
# ============================================================================

# DB (Cloud SQL) — driver psycopg v3 (khớp VM). Config đọc DOCUMENT_SERVICE_DATABASE_URL
# trước, fallback DATABASE_URL (VM dùng DATABASE_URL).
DATABASE_URL=postgresql+psycopg://postgres:***REDACTED-DB-PW***@34.87.63.152:5432/doc_db

# Storage: prod = gcs (SDK native + service-account JSON). s3 chỉ local/e2e.
STORAGE_BACKEND=gcs
GCS_BUCKET=vsf-rag-chatbot-docs-dev
GCP_PROJECT_ID=vsf-rag-chatbot-dev
# google-cloud-storage SDK tự đọc biến này; trỏ tới file SA mount trong compose.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json
