# ============================================================================
# secret.env.example — MẪU cho deploy/env/secret.env (file thật GITIGNORED).
# ----------------------------------------------------------------------------
# Đây cũng là BẢN KÊ secret cần set vào GitHub Secrets (Settings -> Secrets -> Actions).
# Deploy workflow sinh deploy/env/secret.env trên VM từ các GitHub Secrets này.
# Local dev: copy file này -> secret.env, điền giá trị thật.
# ============================================================================

# AI gateway (OpenAI direct: 1 key cho cả embed + LLM)
OPENAI_API_KEY=

# Auth JWT (>=32 ký tự)
JWT_SECRET_KEY=

# Service-to-service tokens (MCP_INTERNAL_TOKEN dùng bởi mcp + query;
# HR_INTERNAL_TOKEN == HR_SERVICE_INTERNAL_TOKEN, dùng bởi hr + mcp)
MCP_INTERNAL_TOKEN=
HR_INTERNAL_TOKEN=
HR_SERVICE_INTERNAL_TOKEN=

# GCS HMAC (S3-interop cho rag-worker). Tạo: gcloud storage hmac create <SA>
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Langfuse client keys (loopback-only; PHẢI khớp LANGFUSE_* trong root .env)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# LangSmith (TẠM TẮT — để trống; bật lại thì thêm 'langsmith' vào OBSERVABILITY_MODE)
# LANGSMITH_API_KEY=
