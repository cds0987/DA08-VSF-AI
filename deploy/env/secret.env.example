# ============================================================================
# secret.env.example — MẪU cho deploy/env/secret.env (file thật GITIGNORED).
# ----------------------------------------------------------------------------
# Đây cũng là BẢN KÊ secret cần set vào GitHub Secrets (Settings -> Secrets -> Actions).
# Deploy workflow RENDER deploy/env/secret.env trên VM từ GitHub Secrets (nguồn DUY NHẤT)
# -> KHÔNG tạo/sửa file này thủ công trên production.
# Local dev: copy file này -> secret.env, điền giá trị thật.
#
# ⚠ BIẾN PHÁI SINH (workflow tự suy, KHÔNG set GitHub Secret riêng — chống trùng/mồ côi):
#   HR_SERVICE_INTERNAL_TOKEN = HR_INTERNAL_TOKEN
#   S3_ACCESS_KEY_ID     = GitHub Secret GCS_HMAC_KEY
#   S3_SECRET_ACCESS_KEY = GitHub Secret GCS_HMAC_SECRET
# ============================================================================

# AI gateway (OpenAI direct: 1 key cho cả embed + LLM)
OPENAI_API_KEY=

# Rerank trả phí qua OpenRouter (RERANK_PROVIDER=cohere, model cohere/rerank-4-pro).
# OPTIONAL: thiếu -> rerank gọi /rerank không Bearer -> 401 -> fallback vector-order (non-fatal).
RERANK_API_KEY=

# Auth JWT (>=32 ký tự)
JWT_SECRET_KEY=

# Service-to-service tokens (MCP_INTERNAL_TOKEN dùng bởi mcp + query;
# HR_INTERNAL_TOKEN dùng bởi hr + mcp — workflow ghi luôn HR_SERVICE_INTERNAL_TOKEN cùng giá trị)
MCP_INTERNAL_TOKEN=
HR_INTERNAL_TOKEN=
HR_SERVICE_INTERNAL_TOKEN=   # phái sinh = HR_INTERNAL_TOKEN (không set GitHub Secret riêng)

# GCS HMAC (S3-interop cho rag-worker). GitHub Secret: GCS_HMAC_KEY / GCS_HMAC_SECRET
S3_ACCESS_KEY_ID=            # phái sinh = GCS_HMAC_KEY
S3_SECRET_ACCESS_KEY=        # phái sinh = GCS_HMAC_SECRET

# Langfuse client keys (loopback-only; PHẢI khớp LANGFUSE_* trong root .env)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# LangSmith (ĐÃ BẬT: OBSERVABILITY_MODE=langfuse,langsmith). Thiếu key -> tự bỏ backend.
LANGSMITH_API_KEY=
