# ============================================================================
# common.env — BIẾN DÙNG CHUNG cho TẤT CẢ backend service (nguồn DUY NHẤT).
# ----------------------------------------------------------------------------
# ⚠ CHỈ CHỨA CONFIG (không secret) — commit thẳng vào git (public repo OK). SECRET nằm
# ở deploy/env/secret.env (GITIGNORED, load CUỐI -> override). Mỗi service load:
# env_file: [common.env, <svc>.env, secret.env] -> file sau override file trước.
# Đổi 1 dòng config ở đây = cả hệ nhận, deploy `git reset --hard` đồng bộ luôn.
#
# ⚠ KHỐI "CONTRACT-CRITICAL": rag-worker (producer) và mcp-service (consumer) PHẢI
#   thấy GIỐNG HỆT, lệch -> mcp search fail-closed. Để ở đây nên không thể lệch.
# Giá trị bên dưới = lấy từ container đang chạy trên VM (2026-06-10) -> deploy không đổi hành vi.
# ============================================================================

# ── Runtime ─────────────────────────────────────────────────────────────────
APP_ENV=production
# APP_STAGE=develop -> hr-service bật lazy mock HR data cho mọi intent (demo chatbot,
# không có HR backend thật). Cần cho hr_query e2e/smoke. KHÔNG phải secret.
APP_STAGE=develop
LOG_LEVEL=INFO

# ── Auth JWT (user phát hành; document + query verify) — PHẢI cùng 1 secret ────
# 🔑 JWT_SECRET_KEY = SECRET -> secret.env. >=32 ký tự, config loader raise lúc boot nếu thiếu.
JWT_ALGORITHM=HS256

# CORS: VM hiện KHÔNG set -> dùng default trong code (localhost). FE đi same-origin
# qua nginx nên không phát sinh CORS. Cần siết domain thật thì thêm CORS_ORIGINS ở đây.

# ── AI gateway  ⚠ CONTRACT-CRITICAL (rag-worker == mcp-service == query) ───────
# OpenAI direct (EMBED_BASE_URL trống) -> 1 key cho cả embed + LLM (gpt-5.4-nano).
AI_PROVIDER=openai
# 🔑 OPENAI_API_KEY = SECRET -> secret.env (1 key cho cả embed + LLM).
EMBED_BASE_URL=http://ai-router:8010/v1
EMBED_API_KEY=
# 2026-06-27: 4b->8b. 4b chỉ 1 provider (DeepInfra) -> engine_overloaded 90% dưới burst
# (đo: ok 4/40). 8b có 3 provider (Nebius/DeepInfra/SiliconFlow) -> OpenRouter load-balance
# -> ok 40/40, rẻ hơn ($0.01 vs $0.02/M).
# DIM=4096 = NATIVE 8b (full chất lượng, KHÔNG MRL-truncate). Collection MỚI tự tạo:
# rag_chatbot__qwen3emb8b__d4096__s2 (auto-migrate reingest 247 doc từ GCS; 4b/2560 cũ giữ rollback).
EMBED_MODEL=qwen/qwen3-embedding-8b
EMBED_DIMENSION=4096

# ── Vector store  ⚠ CONTRACT-CRITICAL — Qdrant nội bộ compose (KHÔNG Qdrant Cloud) ─
VECTOR_DB_PROVIDER=qdrant
VECTOR_COLLECTION=rag_chatbot
VECTOR_DB_URL=http://qdrant:6333
VECTOR_DB_API_KEY=
VECTOR_DB_REQUIRE_API_KEY=false
VECTOR_DB_BASIC_AUTH=
# BM25 hybrid: PHẢI bật cho CẢ rag-worker (ghi) LẪN mcp (đọc) -> 2 bên cùng trỏ
# collection __s{SPARSE_ENCODING_VERSION}. Lệch = mcp đọc collection khác producer -> 0 sources.
# rag-worker.env cũng set VECTOR_HYBRID=true (giữ, redundant an toàn).
VECTOR_HYBRID=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_chatbot

# ── NATS (rag-worker + document-service + query-service) ──────────────────────
NATS_URL=nats://nats:4222
NATS_JETSTREAM_ENABLED=true

# ── Redis (user-service + query-service) ──────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Langfuse tracing (self-host nội bộ VM — "Cloud thu nhỏ") ──────────────────
# Server = service `langfuse` trong compose (xem docker-compose.yml). SẴN SÀNG cho
# MỌI service: chỉ cần thêm SDK `langfuse` + đọc 3 biến này + bật OBSERVABILITY_MODE
# (hoặc cờ tương đương) ở .env riêng. Key cố định (bootstrap headless) -> dùng chung.
# MẶC ĐỊNH các service vẫn OFF -> bật là việc của từng dev khi service sẵn sàng.
LANGFUSE_HOST=http://langfuse:3000
# 🔑 LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY = SECRET -> secret.env (loopback-only, không rotate).
