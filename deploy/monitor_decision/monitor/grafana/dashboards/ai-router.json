              },
              {
                "color": "yellow",
                "value": 0.001
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(airouter_key_429_total[5m])) or vector(0)",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 19,
      "type": "stat",
      "title": "Resolve-fail /5m",
      "description": "sum(rate(airouter_resolve_fail_total[5m])) — no_capacity / unknown_capability. 0 = tốt.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.001
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(airouter_resolve_fail_total[5m])) or vector(0)",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ]
    },
    {
      "id": 701,
      "type": "row",
      "collapsed": false,
      "title": "② Trải nghiệm user — TTFT · Latency",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "panels": []
    },
    {
      "id": 51,
      "type": "table",
      "title": "Trải nghiệm user — TTFT & Latency theo capability (p50/p95/p99 · avg)",
      "description": "TTFT = time-to-first-chunk từ provider (ai-router thấy). Latency = tổng thời gian 1 call. p95/p99 từ histogram (rate theo khoảng đang xem). req/s = lưu lượng.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "instant": true,
          "expr": "histogram_quantile(0.50, sum by(capability,le)(rate(airouter_ttfc_seconds_bucket{capability=~\"$capability\"}[$__range])))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "B",
          "format": "table",
          "instant": true,
          "expr": "histogram_quantile(0.95, sum by(capability,le)(rate(airouter_ttfc_seconds_bucket{capability=~\"$capability\"}[$__range])))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "C",
          "format": "table",
          "instant": true,
          "expr": "histogram_quantile(0.99, sum by(capability,le)(rate(airouter_ttfc_seconds_bucket{capability=~\"$capability\"}[$__range])))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "D",
          "format": "table",
          "instant": true,
          "expr": "sum by(capability)(rate(airouter_call_latency_seconds_sum{capability=~\"$capability\"}[$__range])) / clamp_min(sum by(capability)(rate(airouter_call_latency_seconds_count{capability=~\"$capability\"}[$__range])),0.0001)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "E",
          "format": "table",
          "instant": true,
          "expr": "histogram_quantile(0.95, sum by(capability,le)(rate(airouter_call_latency_seconds_bucket{capability=~\"$capability\"}[$__range])))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "F",
          "format": "table",
          "instant": true,
          "expr": "histogram_quantile(0.99, sum by(capability,le)(rate(airouter_call_latency_seconds_bucket{capability=~\"$capability\"}[$__range])))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "G",
          "format": "table",
          "instant": true,
          "expr": "sum by(capability)(rate(airouter_call_latency_seconds_count{capability=~\"$capability\"}[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "service": true
            },
            "renameByName": {
              "capability": "Capability",
              "Value #A": "TTFT p50",
              "Value #B": "TTFT p95",
              "Value #C": "TTFT p99",
              "Value #D": "Latency avg",
              "Value #E": "Latency p95",
              "Value #F": "Latency p99",
              "Value #G": "req/s"
            },
            "indexByName": {
              "capability": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4,
              "Value #E": 5,
              "Value #F": 6,
              "Value #G": 7
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Latency p95",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "req/s"
            },
            "properties": [
              {
                "id": "unit",
                "value": "reqps"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          }
        ]
      }
    },
    {
      "id": 63,
      "type": "timeseries",
      "title": "TTFT & Latency p95/p99 theo thời gian (spike/trend)",
      "description": "histogram_quantile theo thời gian — bắt latency tăng vọt. TTFT=time-to-first-chunk; Latency=tổng call.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "TTF",
          "expr": "histogram_quantile(0.95, sum by(le)(rate(airouter_ttfc_seconds_bucket{capability=~\"$capability\"}[5m])))",
          "legendFormat": "TTFT p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "TTF",
          "expr": "histogram_quantile(0.99, sum by(le)(rate(airouter_ttfc_seconds_bucket{capability=~\"$capability\"}[5m])))",
          "legendFormat": "TTFT p99",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "Lat",
          "expr": "histogram_quantile(0.95, sum by(le)(rate(airouter_call_latency_seconds_bucket{capability=~\"$capability\"}[5m])))",
          "legendFormat": "Latency p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "Lat",
          "expr": "histogram_quantile(0.99, sum by(le)(rate(airouter_call_latency_seconds_bucket{capability=~\"$capability\"}[5m])))",
          "legendFormat": "Latency p99",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 702,
