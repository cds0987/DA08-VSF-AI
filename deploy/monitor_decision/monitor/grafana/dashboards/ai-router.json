    {
      "id": 6,
      "type": "stat",
      "title": "Lệch tải key (RPM)",
      "description": "(max-min)/avg của RPM giữa các key. ~0 = tải ĐỀU; cao = dồn 1 vài key.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 18,
        "y": 24,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.3
              },
              {
                "color": "red",
                "value": 0.6
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(max(airouter_key_rpm{key_id=~\"$key\"}) - min(airouter_key_rpm{key_id=~\"$key\"})) / clamp_min(avg(airouter_key_rpm{key_id=~\"$key\"}), 0.01)",
          "instant": true,
          "refId": "A",
          "datasource": {
            "type": "prometheus",
