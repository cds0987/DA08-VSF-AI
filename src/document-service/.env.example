# Database (Cloud SQL - doc_db)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/doc_db

# JWT (shared secret - must match User Service)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# NATS
NATS_URL=nats://localhost:4222
NATS_JETSTREAM_ENABLED=true

# GCP Cloud Storage
GCS_BUCKET=rag-chatbot-docs
GCP_PROJECT_ID=vsf-rag-chatbot
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Allow_list loại file upload (chính sách). Rỗng = tất cả loại rag-worker parse được
# (app/supported_formats.json — nguồn chân lý, sinh từ rag-worker reader registry).
# Khai báo subset để siết; loại ngoài manifest -> fail-fast lúc khởi động.
DOC_ALLOWED_EXTENSIONS=pdf,docx,txt,xlsx,csv,pptx,md

