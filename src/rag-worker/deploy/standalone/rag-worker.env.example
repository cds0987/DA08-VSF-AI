# ── rag-worker STANDALONE env (template) ────────────────────────────
# Copy thành rag-worker.env trên VM rồi điền giá trị THẬT. KHÔNG commit file thật.
# .image.env / .env (chứa RAG_WORKER_IMAGE) do CD ghi, KHÔNG để ở đây.

APP_ENV=production
LOG_LEVEL=INFO

# ── AI / Embedding ──────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=replace-me
EMBED_MODEL=text-embedding-3-small
CAPTION_MODEL=gpt-4o-mini
# ⚠️ QUAN TRỌNG (contract fingerprint = collection + model + dimension):
#   text-embedding-3-small CHIỀU GỐC = 1536. configmap k8s đang để 1024 (lệch!).
#   Con số ở ĐÂY phải khớp TUYỆT ĐỐI với EMBED_DIMENSION của mcp-service,
#   và rag-worker phải THỰC SỰ tạo vector đúng chiều này — sai là mcp-service
#   fail-closed (crash) khi verify contract. Chốt 1 lần, dùng đồng nhất 2 bên.
EMBED_DIMENSION=1536

# ── Qdrant (in-VM, qua network compose) ─────────────────────────────
VECTOR_DB_PROVIDER=qdrant
VECTOR_DB_URL=http://qdrant:6333
# VECTOR_DB_API_KEY=    # chỉ cần nếu bật auth / chuyển Qdrant Cloud
VECTOR_COLLECTION=rag_chatbot

# ── Postgres (in-VM) ────────────────────────────────────────────────
POSTGRES_PASSWORD=replace-me
# DATABASE_URL phải khớp POSTGRES_PASSWORD trên. Driver psycopg v3 (KHÔNG asyncpg).
DATABASE_URL=postgresql+psycopg://raguser:replace-me@postgres:5432/rag_db

# ── NATS: DO TEAM KHÁC CẤP (server ở ngoài VM này) ──────────────────
# Trỏ thẳng tới NATS team chung. rag-worker chỉ kết nối LÚC STARTUP, không
# retry nền -> nếu NATS lên sau, phải: docker compose restart rag-worker.
NATS_URL=nats://NATS_HOST_FROM_OTHER_TEAM:4222
# Tên stream PHẢI khớp cái team NATS tạo (xem infra/nats/jetstream.conf).
NATS_STREAM=DOC_EVENTS
# Nếu NATS team bật auth, thêm theo dạng họ cấp, ví dụ:
# NATS_TOKEN=...            (token auth)
# hoặc NATS_URL=nats://user:pass@host:4222

# ── Nguồn file gốc: Google Cloud Storage qua S3-interop ─────────────
PARSER_IMPL=s3
S3_ENDPOINT_URL=https://storage.googleapis.com
S3_ACCESS_KEY_ID=replace-me          # GCS HMAC key
S3_SECRET_ACCESS_KEY=replace-me      # GCS HMAC secret
# S3_BUCKET / SOURCE_ROOT / ARTIFACT_ROOT theo quy ước code:
SOURCE_ROOT=/data/source
ARTIFACT_ROOT=/data/artifacts

# ── Worker tuning ───────────────────────────────────────────────────
INGEST_WORKER_COUNT=2
INGEST_WORKER_POLL_INTERVAL_SECONDS=0.5

# ── Langfuse tracing (mặc định OFF, bật khi cần soi ingest) ─────────
LANGFUSE_ENABLED=0
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_SAMPLE_RATE=0.0
LANGFUSE_TRACE_ON_ERROR=1
