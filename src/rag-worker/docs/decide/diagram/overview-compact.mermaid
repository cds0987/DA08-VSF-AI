%% =====================================================================
%% V2 — OVERVIEW (compact) — pipeline end-to-end ở mức 1 nhìn
%% Bản chi tiết: overview.mermaid · stages: ingestion.mermaid / scaling.mermaid
%% =====================================================================
flowchart LR
    S3[("S3 Documents")]

    DETECT["Change Detector<br/>event + scanner"]
    Q1[("File Queue")]
    PARSE["Parse Workers<br/>convert/OCR/split"]
    ART[("Canonical Markdown")]

    Q2[("Section Queue")]
    INDEX["Index Workers<br/>caption + upsert"]

    COAL["Embedding Coalescer<br/>batch + cache"]
    EMB["Embedding Model"]
    QDRANT[("Qdrant")]
    META[("Metadata DB")]
    DLQ[("DLQ")]

    S3 --> DETECT --> Q1 --> PARSE --> ART
    PARSE --> Q2 --> INDEX

    INDEX -->|"caption"| COAL
    COAL --> EMB
    EMB --> COAL
    COAL -->|"vector"| INDEX

    INDEX --> QDRANT
    INDEX --> META

    PARSE -. failed .-> DLQ
    INDEX -. failed .-> DLQ
    DLQ -.-> META
