# ============================================================================
# rag-service — environment template
# Copy to `.env` and fill the <...> placeholders. `.env` is gitignored.
#   cp .env.example .env
# Empty value = "feature off / use built-in default". Comments note each default.
# ============================================================================

# --- Runtime mode ----------------------------------------------------------
# development | production. In `production` the service FAILS CLOSED on startup
# if the AI provider is offline, the vector store is in-process, or metadata is
# not Postgres (i.e. not durable). Keep `development` for the offline MVP/eval.
APP_ENV=development
LOG_LEVEL=INFO
PIPELINE_CONFIG=config.yaml
PIPELINE_PROFILE=baseline

# --- AI provider (embed / caption / rerank / ocr) --------------------------
# AI_PROVIDER: auto | openai | offline
#   auto    -> "openai" if an embed API key OR EMBED_BASE_URL is set, else "offline"
#   offline -> synthetic hash embeddings (NO network, NO quality) — MVP/tests only
#   openai  -> real provider via the OpenAI SDK (works with OpenRouter/any
#              OpenAI-compatible gateway by setting *_BASE_URL below)
AI_PROVIDER=auto

# One key/base-url set covers all capabilities; they cascade embed -> caption
# -> rerank -> ocr unless overridden per capability.
# For OpenAI direct: leave *_BASE_URL empty, set OPENAI_API_KEY.
# For OpenRouter/gateway: set EMBED_BASE_URL=https://openrouter.ai/api/v1 (etc.)
OPENAI_API_KEY=<your-api-key>
EMBED_BASE_URL=
# Per-capability overrides (optional — leave empty to inherit from embed):
EMBED_API_KEY=
CAPTION_BASE_URL=
CAPTION_API_KEY=
RERANK_BASE_URL=
RERANK_API_KEY=
OCR_BASE_URL=
OCR_API_KEY=

# Models (defaults shown). RERANK/OCR default to CAPTION_MODEL if unset.
EMBED_MODEL=text-embedding-3-small
CAPTION_MODEL=gpt-4o-mini
RERANK_MODEL=gpt-4o-mini
OCR_MODEL=gpt-4o-mini
# Toggle caption-at-ingest without code changes: true -> embed caption, false -> embed child content directly.
CAPTION_ENABLED=true
# Select rerank strategy without code changes: llm | lexical | none.
# NOTE: with `none`, rerank_score = raw vector score; pair it with RERANK_THRESHOLD=0.0
# for a fair A/B (the 0.7 default is calibrated for rerank scores, not raw cosine).
RERANK_PROVIDER=llm
# MUST match the embedding model's output size (ingest==query==store invariant).
# text-embedding-3-small -> 1536 · BGE-M3 -> 1024 · OfflineProvider -> 256.
EMBED_DIMENSION=1536

# --- Metadata DB -----------------------------------------------------------
# Empty -> in-memory repository (NOT durable; rejected in production).
# Postgres MUST use the postgresql+psycopg:// driver (sync SQLAlchemy + psycopg v3).
# SQLite (sqlite:///rag-service.db) also works for local dev.
DATABASE_URL=

# --- Vector store ----------------------------------------------------------
VECTOR_DB_PROVIDER=qdrant
# Empty VECTOR_DB_URL -> Qdrant embedded :memory: (in_process, lost on restart).
# Durable: http://qdrant:6333 (self-host) or https://...qdrant.io (cloud).
VECTOR_DB_URL=
VECTOR_DB_API_KEY=
# Force API-key requirement on/off (auto-required for *.qdrant.io / zillizcloud.com).
VECTOR_DB_REQUIRE_API_KEY=
# Do NOT encode dimension here; index_id() appends __d{EMBED_DIMENSION} automatically.
VECTOR_COLLECTION=rag_chatbot

# --- File ingest / parser --------------------------------------------------
# PARSER_IMPL: local | s3
#   local -> read sources from the local filesystem under SOURCE_ROOT.
#   s3    -> fetch source_uri=s3://bucket/key (or gs://) from object storage, then
#            parse locally. Use when the backend sends only the object URL.
PARSER_IMPL=local
# Allow-list root: parser only reads sources under this path (path-traversal guard).
# Also the download dir for the `s3` parser (temp objects are streamed here, then deleted).
# For the validation e2e the test sets this itself; for API file-ingest point it
# at your source dir, e.g. ./eval/validation to try the sample corpus.
SOURCE_ROOT=./eval/validation
ARTIFACT_ROOT=./.artifacts
MAX_SOURCE_SIZE_BYTES=10485760
PARSER_MAX_WORKERS=2
# OCR/vision cost guards (only used when a source needs vision via the AI gateway):
MAX_OCR_PAGES=25
PDF_OCR_SCALE=2.0
OCR_MIN_IMAGE_PIXELS=64

# --- S3/GCS source fetch (PARSER_IMPL=s3) ----------------------------------
# Service downloads source_uri=s3://bucket/key itself. Anti-crash guards below.
# GCS via S3-interop: S3_ENDPOINT_URL=https://storage.googleapis.com + HMAC keys.
# R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com · AWS: leave endpoint empty.
# (S3_* falls back to the R2_* vars at the bottom if unset.)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
# Anti-crash knobs: reject oversize via HEAD before download; stream to disk with a
# hard byte cap; bound concurrent downloads; time out hung transfers.
MAX_REMOTE_SOURCE_BYTES=10485760
S3_FETCH_CONCURRENCY=4
S3_DOWNLOAD_CHUNK_BYTES=1048576
S3_CONNECT_TIMEOUT=10
S3_READ_TIMEOUT=60
S3_MAX_ATTEMPTS=3

# --- Chunking / retrieval --------------------------------------------------
SECTION_MAX_WORDS=220
CHILD_MAX_WORDS=90
CHILD_OVERLAP_WORDS=15
SEARCH_TOP_K=20
RERANK_TOP_K=3
RERANK_THRESHOLD=0.7

# --- NATS ingest (doc.ingest -> doc.status) --------------------------------
# Ingest đi qua NATS JetStream: BE publish doc.ingest, rag-worker subscribe ->
# enqueue vào job-queue DB -> publish doc.status. KHÔNG set NATS_URL -> tắt NATS
# (ingest qua NATS không chạy; HTTP search vẫn hoạt động). Cần `pip install nats-py`.
# doc.ingest payload: { doc_id, gcs_key, file_type, document_name?, classification?, ... }
#   gcs_key = địa chỉ object (s3://bucket/key | gs://bucket/key) -> dùng làm source_uri
#   (đặt PARSER_IMPL=s3 để rag-worker tự tải an toàn từ GCS/S3).
NATS_URL=
NATS_STREAM=DOCS
NATS_DOC_INGEST_SUBJECT=doc.ingest
NATS_DOC_STATUS_SUBJECT=doc.status
NATS_DURABLE=rag-worker-ingest
NATS_QUEUE=rag-worker

# --- Ingest worker / durable job lease -------------------------------------
INGEST_WORKER_COUNT=1
INGEST_WORKER_POLL_INTERVAL_SECONDS=0.5
CLAIM_STALE_TIMEOUT_SECONDS=300
CLAIM_HEARTBEAT_INTERVAL_SECONDS=30
CLAIM_REAPER_INTERVAL_SECONDS=30

# --- Job-log retention -----------------------------------------------------
JOBLOG_RETENTION_DAYS=30
JOBLOG_PRUNE_INTERVAL_SECONDS=3600

# --- Edge guards (API) -----------------------------------------------------
MAX_REQUEST_BODY_BYTES=2097152
MAX_MARKDOWN_BYTES=524288
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# --- Eval gate (tests/eval + validation corpus) ----------------------------
# Set to 1 to run golden/validation eval against the REAL provider above
# (requires OPENAI_API_KEY etc.). Unset/0 -> offline plumbing check only.
RAG_EVAL_REAL_PROVIDER=
RAG_EVAL_MAX_P95_MS=5000
# Quantitative retrieval gate thresholds (tests/eval golden metrics: recall@k/MRR/nDCG).
RAG_EVAL_MIN_RECALL=1.0
RAG_EVAL_MIN_MRR=0.99
RAG_EVAL_MIN_NDCG=0.99

# --- Benchmark harness (scripts/benchmark.py) ------------------------------
# Measures per-stage time + tracemalloc memory + recall under the CURRENT env config
# (swap one line above, e.g. RERANK_PROVIDER / EMBED_MODEL, then re-run to A/B):
#   python scripts/benchmark.py --repeat 20 --csv bench.csv
# No extra env needed — it reads the same variables the service does.

# Optional: remote-Qdrant contract test opt-in (tests/core_engine/test_qdrant_remote_contract.py)
QDRANT_URL=
QDRANT_API_KEY=

# --- Cloudflare R2 (S3-compatible) -----------------------------------------
# Used by scripts/upload_validation_to_r2.py + tests/e2e/test_r2_source_ingest_search.py,
# AND as fallback for the S3_* vars above when PARSER_IMPL=s3 (service `s3` parser).
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com (region "auto").
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PREFIX=validation/
