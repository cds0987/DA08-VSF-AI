APP_ENV=development
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///rag-service.db

AI_PROVIDER=offline
OPENAI_API_KEY=
EMBED_MODEL=text-embedding-3-small
CAPTION_MODEL=gpt-4o-mini
RERANK_MODEL=gpt-4o-mini
EMBED_DIMENSION=1024

VECTOR_DB_PROVIDER=qdrant
VECTOR_DB_URL=
VECTOR_DB_API_KEY=
VECTOR_COLLECTION=rag_chatbot

SOURCE_ROOT=./sample-data
ARTIFACT_ROOT=./.artifacts
MAX_SOURCE_SIZE_BYTES=10485760
MAX_REQUEST_BODY_BYTES=2097152
MAX_MARKDOWN_BYTES=524288

SEARCH_TOP_K=20
RERANK_TOP_K=3
RERANK_THRESHOLD=0.7

INGEST_WORKER_COUNT=1
INGEST_WORKER_POLL_INTERVAL_SECONDS=0.5

JOBLOG_RETENTION_DAYS=30
JOBLOG_PRUNE_INTERVAL_SECONDS=3600

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
