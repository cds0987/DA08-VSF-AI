# Database
USER_SERVICE_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/user_db

# JWT
# Must match services that verify user-service access tokens.
JWT_SECRET_KEY=replace-with-a-long-random-secret-for-local-dev
ACCESS_TOKEN_TTL_MINUTES=10080
REFRESH_TOKEN_TTL_DAYS=7

# Login protection
FAILED_LOGIN_THRESHOLD=5
LOCKOUT_MINUTES=15
