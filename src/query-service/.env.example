# Query Service local defaults.
SERVICE_NAME=query-service
APP_ENV=development

# Database (used when NATS_MODE=nats). Adjust DB name/port to your local setup.
DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:55432/rag_chatbot

# Auth: mock | jwt | user_service
# - mock: offline tests with mock tokens.
# - jwt: decode User Service JWT locally; JWT_SECRET_KEY must match user-service.
# - user_service: call USER_SERVICE_URL/auth/me to reject inactive/deactivated users.
AUTH_MODE=mock
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
USER_SERVICE_URL=http://localhost:8000
AUTH_HTTP_TIMEOUT_SECONDS=5

# Redis — JWT blacklist + rate limiting + semantic cache in later adapters
REDIS_URL=redis://localhost:6379/0
RATE_LIMITER_MODE=memory

# LLM: openai | mock
# Default is mock for offline/API tests. Set LLM_MODE=openai only when you want real LLM calls.
LLM_MODE=mock
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=30

# MCP: mock | real. Legacy mcp is accepted as an alias for real during migration.
# real uses the official MCP SDK Streamable HTTP client at MCP_SERVICE_URL(/mcp).
MCP_MODE=mock
MCP_SERVICE_URL=http://localhost:8003
MCP_TIMEOUT_SECONDS=10
MCP_INTERNAL_TOKEN=
# Circuit breaker: trips after MCP_CIRCUIT_FAIL_MAX consecutive errors; resets after RESET_TIMEOUT seconds.
MCP_CIRCUIT_FAIL_MAX=5
MCP_CIRCUIT_RESET_TIMEOUT_SECONDS=30
# Tool routing mode: legacy | native
# - legacy (default): typed methods rag_search/hr_query — stable, unchanged behaviour.
# - native: calls list_tool_specs() + generic call_tool(); new mcp-service tools need 0 query-service changes.
TOOL_ROUTING_MODE=legacy
# Seconds to cache list_tool_specs() response from mcp-service. 0 = no cache (re-fetches every request).
MCP_TOOL_CACHE_TTL_SECONDS=0

# NATS: mock | nats.
# - mock: no subscriber, in-memory ACL/notifications.
# - nats: subscribe doc.access and notify.doc_new via JetStream, persist to DATABASE_URL.
NATS_MODE=mock
NATS_URL=nats://127.0.0.1:4222
NATS_JETSTREAM_ENABLED=true

# Qdrant — semantic cache / retrieval parity config for later adapters
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_chatbot

# Langfuse tracing. Set OBSERVABILITY_MODE=langfuse in production + fill in the keys.
# off (default) = no tracing, works fully offline (no langfuse package calls made).
OBSERVABILITY_MODE=off
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3100

# Guardrails. Set GUARDRAILS_MODE=llm_guard in production (required by SA doc §5.2.2).
# off (default) = no-op pass-through; llm-guard package not imported.
GUARDRAILS_MODE=off

# CORS — chat app :3000, admin app :3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# In-memory Phase 1 controls.
SEMANTIC_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_THRESHOLD=0.95
RAG_SCORE_THRESHOLD=0.70
RAG_RESULT_LIMIT=3
QUERY_RATE_LIMIT_PER_MINUTE=20
NOTIFICATION_KEEPALIVE_SECONDS=25
NATS_PROCESSED_EVENT_MAX_SIZE=10000
NATS_PROCESSED_EVENT_TTL_SECONDS=86400

# Legacy/dev intent classifier config. Production routing uses guarded tool decision:
# LLM chooses rag_search/hr_query, backend validates and injects user_id/document_ids.
INTENT_CLASSIFIER_MODE=hybrid
INTENT_RULE_CONFIDENCE_THRESHOLD=0.90
INTENT_EMBEDDING_CONFIDENCE_THRESHOLD=0.78
INTENT_EMBEDDING_MARGIN=0.08
INTENT_LLM_CONFIDENCE_THRESHOLD=0.70
INTENT_LLM_MODEL=gpt-4o-mini
INTENT_LLM_TIMEOUT_SECONDS=5

# Agent settings
# AGENT_MAX_ITERATIONS: max tool-call iterations before the agent emits the final answer.
AGENT_MAX_ITERATIONS=3

# LangGraph agent (canonical): true | false
# - true (default): use LangGraph graph-based agent. Requires LLM_MODE=openai + OPENAI_API_KEY.
# - false: fall back to legacy direct-orchestration (mock / no-key environments).
USE_LANGGRAPH=true

# Dev-only endpoints, for manual mock notification tests.
ENABLE_DEV_ENDPOINTS=false
