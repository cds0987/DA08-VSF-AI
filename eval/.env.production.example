# Production VM eval config. Copy to eval/.env.production and fill real values.
# Never commit eval/.env.production.

# GCP target
GCP_PROJECT_ID=vsf-rag-chatbot-dev
GCP_VM_NAME=vsf-rag-demo-vm
GCP_ZONE=asia-southeast1-a
REMOTE_EVAL_DIR=/tmp/vsf-eval
PROD_APP_DIR=/home/<vm-user>/DA08-VSF
GCP_TUNNEL_THROUGH_IAP=true

# Service URLs as seen from inside the VM
USER_URL=http://localhost:8000
QUERY_URL=http://localhost:8001
DOC_URL=http://localhost:8002
MCP_URL=http://localhost:8003

# Production admin account used by eval
SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_PASSWORD=replace-me

# RAGAS evaluator key. Prefer Secret Manager/DevOps-provided value.
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional if production JWT differs from the eval default and ACL smoke is enabled elsewhere.
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
MCP_INTERNAL_TOKEN=

# Safety rails for production eval
EVAL_PRODUCTION_READONLY=true
EVAL_REQUIRE_INDEXED_DOCS=true
EVAL_TOTAL_EMPLOYEES=100
