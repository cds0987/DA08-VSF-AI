PROD_BASE_URL=https://your-production-host.example.com
PROD_API_BASE_URL=
PROD_EMAIL=eval.user@company.com
PROD_PASSWORD=change-me
PROD_ACCESS_TOKEN=
PROD_REFRESH_TOKEN=

USER_SERVICE_PATH=/api/user
QUERY_SERVICE_PATH=/api/query
DOCUMENT_SERVICE_PATH=/api/documents

# Optional. Use this only when production exposes the internal MCP endpoint to
# the runner network. Without it, output still contains public query sources.
MCP_URL=
MCP_INTERNAL_TOKEN=

# Optional gateway auth header value used by the frontend axios client.
GATEWAY_BASIC_AUTH=

DATASET_ROOT=eval/dataset
DATASET=dataset_new
QUESTION_TIMEOUT_SECONDS=30
CONCURRENCY=5
LIMIT=30

# Optional question selection. When any selector below is set, LIMIT is ignored
# unless --limit is passed on the CLI.
INCLUDE_DOC_IDS=
EXCLUDE_DOC_IDS=
QUESTIONS_PER_DOC=
