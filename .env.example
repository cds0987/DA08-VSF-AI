# ============================================================================
# .env.example — MẪU cho file .env ở ROOT (GITIGNORED).
# ----------------------------------------------------------------------------
# docker-compose TỰ ĐỘNG nạp file .env này để nội suy ${VAR} trong docker-compose.yml
# (KHÁC với env_file: chỉ block `environment:` + ${VAR} mới được substitution).
# Deploy workflow sinh .env trên VM từ GitHub Secrets. Local: copy -> .env, điền thật.
# ============================================================================

# Image registry (deploy đã export sẵn qua SSH; local để mặc định nếu tự build)
DOCKERHUB_USERNAME=
IMAGE_TAG=develop

# Postgres app (1 password DUY NHẤT -> dùng cho app-postgres + mọi DATABASE_URL service)
POSTGRES_PASSWORD=

# New Relic APM (license key region EU)
NEW_RELIC_LICENSE_KEY=

# Seed admin (one-shot seed-user)
SEED_ADMIN_PASSWORD=

# ── Langfuse server (self-host loopback-only; internal nên KHÔNG rotate gấp) ──
# LANGFUSE_PUBLIC_KEY / SECRET_KEY PHẢI khớp giá trị trong deploy/env/secret.env
# (compose dùng cho LANGFUSE_INIT_*; app service dùng qua secret.env).
LANGFUSE_DB_PASSWORD=
NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_INIT_USER_PASSWORD=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
